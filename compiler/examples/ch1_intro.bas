REM ============================================================
REM Chapter 1: Introduction
REM Program structure, line numbers, PRINT, END
REM ============================================================
REM Line numbers organise execution order.
REM RUN starts from the lowest line number.
REM PRINT outputs text; END terminates the program.

100 PRINT "=== TI-99/4A BASIC ==="
110 PRINT "Line numbers set execution order."
120 PRINT "Statements run top to bottom"
130 PRINT "unless a branch redirects flow."
140 PRINT
150 PRINT "RUN   - execute program"
160 PRINT "LIST  - display source"
170 PRINT "NEW   - clear memory"
180 PRINT "NUM   - auto line numbering"
190 PRINT "RES   - resequence lines"
200 END
